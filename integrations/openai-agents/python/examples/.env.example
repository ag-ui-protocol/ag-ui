# OpenAI API Key (required)
OPENAI_API_KEY=sk-your-key-here

# Optional: override the model used by every example agent
# OPENAI_DEFAULT_MODEL=gpt-4.1-mini

# Optional: OPENAI_AGENTS_DISABLE_TRACING is the OpenAI Agents SDK's own env
# var for tracing. SDK default is "false" (tracing on). Set to "true" to disable tracing.
# OPENAI_AGENTS_DISABLE_TRACING=false
